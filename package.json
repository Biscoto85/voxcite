{
  "name": "voxcite",
  "version": "0.1.0",
  "private": true,
  "description": "VoxCité — On fait parler la cité.",
  "workspaces": [
    "packages/shared",
    "packages/client",
    "packages/server"
  ],
  "scripts": {
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:server": "npm run dev --workspace=packages/server",
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "build:shared": "npm run build --workspace=packages/shared",
    "build:client": "npm run build --workspace=packages/client",
    "build:server": "npm run build --workspace=packages/server",
    "build": "npm run build:shared && concurrently \"npm run build:client\" \"npm run build:server\"",
    "start": "pm2 start ecosystem.config.js",
    "db:generate": "npm run db:generate --workspace=packages/server",
    "db:migrate": "npm run db:migrate --workspace=packages/server",
    "db:seed": "npm run db:seed --workspace=packages/server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "pm2": "^5.4.0"
  }
}
