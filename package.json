{
  "name": "voxcite",
  "version": "0.1.0",
  "private": true,
  "description": "VoxCité — On fait parler la cité.",
  "scripts": {
    "dev:client": "pnpm --filter @voxcite/client dev",
    "dev:server": "pnpm --filter @voxcite/server dev",
    "dev": "concurrently \"pnpm run dev:client\" \"pnpm run dev:server\"",
    "build:shared": "pnpm --filter @voxcite/shared build",
    "build:client": "pnpm --filter @voxcite/client build",
    "build:server": "pnpm --filter @voxcite/server build",
    "build": "pnpm run build:shared && concurrently \"pnpm run build:client\" \"pnpm run build:server\"",
    "start": "pm2 start ecosystem.config.js",
    "db:generate": "pnpm --filter @voxcite/server db:generate",
    "db:migrate": "pnpm --filter @voxcite/server db:migrate",
    "db:seed": "pnpm --filter @voxcite/server db:seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "pm2": "^5.4.0"
  }
}
