# PartiPrism — Production environment
# Copier ce fichier vers /var/www/partiprism/.env et remplir les valeurs

# Server
NODE_ENV=production
PORT=3001

# PostgreSQL (user: partiprism, db: partiprisms)
DATABASE_URL=postgresql://partiprism:VOTRE_MDP_ICI@localhost:5432/partiprisms

# Anthropic API (pour l'analyse IA)
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# CORS — domaines autorisés (production)
ALLOWED_ORIGINS=https://partiprism.fr,https://www.partiprism.fr
